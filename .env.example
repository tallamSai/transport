# Set to false for real Firebase (required to leave mock / offline demo mode)
EXPO_PUBLIC_USE_MOCK=false
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Maps: create a key in Google Cloud → APIs & Services → Credentials.
# Enable "Maps SDK for Android" and "Maps SDK for iOS". Restrict the key to your app.
# The key is read from app.config.js (android / ios) — rebuild native apps after changing it:
#   npx expo prebuild   or   eas build
# Expo Go may not pick up your custom key; use a development build for reliable maps.
EXPO_PUBLIC_GOOGLE_MAPS_KEY=

# Optional: Google Sign-In on iOS/Android (OAuth 2.0 Web client ID from Firebase / Google Cloud)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
